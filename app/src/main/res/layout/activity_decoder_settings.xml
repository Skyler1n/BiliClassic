<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bili_texture_background">

    <!-- 顶栏 -->
    <RelativeLayout
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:contentDescription="返回"
            android:padding="1dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/decoder_pref_title"
            android:textColor="#333333"
            android:textSize="18sp" />

    </RelativeLayout>

    <!-- 粉色分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:background="#D86DA5" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="6.0dp"
        android:background="@drawable/shadow_top_dig"
        android:contentDescription="@null" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ========== 软件解码 ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/decoder_pref_category_sw_decode"
                android:textSize="15sp"
                android:textColor="#D86DA5"
                android:textStyle="bold" />

            <!-- 画面队列大小 -->
            <LinearLayout
                android:id="@+id/item_pictq_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_pictq_size"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/text_pictq_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="选择" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_pictq_size"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 最大帧率 -->
            <LinearLayout
                android:id="@+id/item_maxfps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_maxfps"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/text_maxfps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="选择" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_maxfps"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 丢帧策略 -->
            <LinearLayout
                android:id="@+id/item_framedrop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_framedrop"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/text_framedrop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="选择" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_framedrop"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 跳过循环滤波 -->
            <LinearLayout
                android:id="@+id/item_skip_loop_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_skip_loop_filter"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/text_skip_loop_filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="选择" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_skip_loop_filter"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 跳过非参考帧 -->
            <LinearLayout
                android:id="@+id/item_skip_frame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_skip_frame"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/text_skip_frame"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginRight="8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="选择" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_skip_frame"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="#E0E0E0" />

            <!-- ========== 播放控制 ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/decoder_pref_category_playctl"
                android:textSize="15sp"
                android:textColor="#D86DA5"
                android:textStyle="bold" />

            <!-- 禁用视频 -->
            <LinearLayout
                android:id="@+id/item_video_disabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_vn"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <CheckBox
                        android:id="@+id/checkbox_video_disabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="false" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_vn"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 禁用音频 -->
            <LinearLayout
                android:id="@+id/item_audio_disabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_an"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <CheckBox
                        android:id="@+id/checkbox_audio_disabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="false" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_an"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="#E0E0E0" />

            <!-- ========== 音频输出 ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/decoder_pref_category_audio"
                android:textSize="15sp"
                android:textColor="#D86DA5"
                android:textStyle="bold" />

            <!-- OpenSL ES -->
            <LinearLayout
                android:id="@+id/item_opensles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:clickable="true"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decoder_title_opensles"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <CheckBox
                        android:id="@+id/checkbox_opensles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="false" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/decoder_summary_opensles"
                    android:textSize="12sp"
                    android:textColor="#999999" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
