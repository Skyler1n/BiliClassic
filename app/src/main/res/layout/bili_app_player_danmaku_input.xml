<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/danmaku_input_view"
        android:background="#000000"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp">
        <ImageView
            android:id="@+id/clear"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/ic_clear_danmaku"
            android:contentDescription="@null"
            style="@style/PlayerControlBarButton"/>
        <EditText
            android:textColor="@color/global__text"
            android:textColorHint="#80ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/input"
            android:background="#cc333333"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:hint="@string/VideoView_danmaku_input_hint"
            android:layout_weight="1"
            android:inputType="text"
            android:windowSoftInputMode="stateVisible"
            android:imeOptions="actionSend"
            android:imeActionLabel="@string/send"
            style="@style/LoginInput"/>
        <ImageView
            android:id="@+id/send"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/ic_confirm_send"
            android:contentDescription="@null"
            style="@style/PlayerControlBarButton"/>
    </LinearLayout>
    <include
        android:id="@+id/danmaku_input_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        layout="@layout/bili_app_player_danmaku_input_options"/>
</LinearLayout>
