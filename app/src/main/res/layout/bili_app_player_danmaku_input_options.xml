<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@+id/danmaku_input_view"
    android:background="#000000"
    android:paddingBottom="5dp"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="40dp">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/input_options_basic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <RadioGroup
            android:orientation="horizontal"
            android:id="@+id/input_options_group_textsize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkedButton="@+id/input_options_medium_textsize">
            <RadioButton
                android:id="@+id/input_options_small_textsize"
                android:background="@drawable/ic_btn_player_danmaku_input_options_small_textsize"
                style="@style/DanmakuInputOptionRadioButton"/>
            <RadioButton
                android:id="@+id/input_options_medium_textsize"
                android:background="@drawable/ic_btn_player_danmaku_input_options_medium_textsize"
                style="@style/DanmakuInputOptionRadioButton"/>
        </RadioGroup>
        <RadioGroup
            android:orientation="horizontal"
            android:id="@+id/input_options_group_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:checkedButton="@+id/input_options_rl_type">
            <RadioButton
                android:id="@+id/input_options_top_type"
                android:background="@drawable/ic_btn_player_danmaku_input_options_top_type"
                style="@style/DanmakuInputOptionRadioButton"/>
            <RadioButton
                android:id="@+id/input_options_rl_type"
                android:background="@drawable/ic_btn_player_danmaku_input_options_rl_type"
                style="@style/DanmakuInputOptionRadioButton"/>
            <RadioButton
                android:id="@+id/input_options_bottom_type"
                android:background="@drawable/ic_btn_player_danmaku_input_options_bottom_type"
                style="@style/DanmakuInputOptionRadioButton"/>
        </RadioGroup>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/input_options_more"
        android:background="@drawable/bili_player_control_item_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp">
        <RadioButton
            android:id="@+id/input_options_color_current"
            android:background="@color/_bkgd__white_abs"
            android:clickable="false"
            android:checked="true"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/input_options_color_more_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:src="@drawable/ic_player_danmaku_input_more_color"
            android:contentDescription="@null"/>
    </LinearLayout>
    <RadioGroup
        android:orientation="horizontal"
        android:id="@+id/input_options_color_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:checkedButton="@+id/input_options_color_white">
        <RadioButton
            android:id="@+id/input_options_color_white"
            android:tag="ffffff"
            android:background="@color/_bkgd__white_abs"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_red"
            android:tag="e70012"
            android:background="#e70012"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_yellow"
            android:tag="fef102"
            android:background="#fef102"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_green"
            android:tag="009843"
            android:background="#009843"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_blue"
            android:tag="00a0ea"
            android:background="#00a0ea"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_pink"
            android:tag="e2027f"
            android:background="#e2027f"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_light_green"
            android:tag="90c320"
            android:background="#90c320"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_drak_blue"
            android:tag="002e72"
            android:background="#002e72"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_orange"
            android:tag="f0ab2a"
            android:background="#f0ab2a"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_purple"
            android:tag="683a7b"
            android:background="#683a7b"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_lite_blue"
            android:tag="84c0cb"
            android:background="#84c0cb"
            style="@style/DanmakuInputOptionColorRadioButton"/>
        <RadioButton
            android:id="@+id/input_options_color_brown"
            android:tag="927939"
            android:background="#927939"
            style="@style/DanmakuInputOptionColorRadioButton"/>
    </RadioGroup>
</LinearLayout>
