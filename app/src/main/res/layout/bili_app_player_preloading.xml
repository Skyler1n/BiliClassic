<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/videoplay__preloading_background"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/tv_chan_animation"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@anim/bili_loading_tv_chan"
        android:scaleType="fitXY"
        android:layout_centerInParent="true"
        android:contentDescription="@null"/>
    <TextView
        android:textColor="@color/videoplay__preloading_status_bar_text"
        android:gravity="bottom"
        android:id="@+id/video_preloading_status_bar"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="@dimen/player_preloading_status_padding_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:lineSpacingMultiplier="1.2"/>
    <TextView
        android:textColor="@color/global__text"
        android:gravity="center"
        android:id="@+id/press_back_to_exit"
        android:background="@color/videoplay__preloading_background_translucent"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/PreloadingView_press_back_to_exit"
        android:layout_below="@+id/tv_chan_animation"
        android:layout_centerInParent="true"/>
    <TextView
        android:textColor="#717171"
        android:gravity="center"
        android:id="@+id/random_tips"
        android:background="#acacac"
        android:paddingLeft="8dp"
        android:paddingTop="2dp"
        android:paddingRight="8dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
    <FrameLayout
        android:id="@+id/preloading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <ImageView
        android:id="@+id/back"
        android:focusable="true"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ica_light_ic_action_previous_item"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:contentDescription="@null"
        style="@style/TitleBarButton"/>
    <ImageView
        android:id="@+id/refresh"
        android:visibility="invisible"
        android:layout_marginTop="8dp"
        android:layout_marginRight="8dp"
        android:src="@drawable/ica_light_ic_action_refresh"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:contentDescription="@null"
        style="@style/TitleBarButton"/>
    <Button
        android:textSize="15sp"
        android:textColor="@color/TextColorBlack"
        android:gravity="center_vertical"
        android:id="@+id/retry_tips"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/PlayerReactTips_retry_loading"
        android:layout_toLeftOf="@+id/refresh"
        android:contentDescription="@null"
        style="@style/TitleBarButton"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/TextColorBlack"
        android:id="@+id/refresh_tips"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="9dp"
        android:layout_below="@+id/refresh"
        android:layout_alignRight="@+id/refresh"
        style="@style/TitleBarButton"/>
</RelativeLayout>
