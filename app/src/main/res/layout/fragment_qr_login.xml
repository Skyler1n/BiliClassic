<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bili_texture_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <!-- 方形容器，强制裁剪为正方形 -->
        <LinearLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="#F0F0F0"
            android:gravity="center">

            <ImageView
                android:id="@+id/qrImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bili_default_image_tv_with_bg"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/scanStat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="请使用B站APP扫码登录"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center" />

        <!-- 手动登录按钮 -->
        <Button
            android:id="@+id/btn_manual_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="手动登录"
            android:background="#D86DA5"
            android:textColor="#FFFFFF"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textSize="12sp" />

        <!-- 返回主页按钮 -->
        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="返回主页"
            android:background="#D86DA5"
            android:textColor="#FFFFFF"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>