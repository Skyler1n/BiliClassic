<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:descendantFocusability="blocksDescendants">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:focusableInTouchMode="true">

        <!-- 顶部分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#FCA3C5" />

        <!-- 封面 + 标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="100dp"
                android:layout_height="70dp"
                android:background="#FFFFFF"
                android:padding="2dp">

                <ImageView
                    android:id="@+id/iv_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bili_default_image_tv_with_bg"
                    android:scaleType="centerCrop"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="视频标题"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginLeft="10dp"
                android:lines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- 灰色分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#CCCCCC" />

        <!-- UP主信息 + 播放按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_up_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UP主: "
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/tv_up_name_new"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FF6699"
                        android:singleLine="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp">

                    <TextView
                        android:id="@+id/tv_play"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="播放: 0"
                        android:textColor="#666666"
                        android:layout_marginRight="50dp" />

                    <TextView
                        android:id="@+id/tv_danmaku"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="弹幕: 0"
                        android:textColor="#666666" />

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btn_play"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="点击播放"
                android:textColor="#FFFFFF"
                android:background="#D86DA5"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- 灰色分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#CCCCCC" />

        <!-- 标签容器 -->
        <LinearLayout
            android:id="@+id/tags_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="0dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp" />

        <!-- 灰色分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#CCCCCC" />

        <!-- 简介内容 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="这里显示视频的简介内容"
                android:textSize="14sp"
                android:textColor="#333333"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- 简介下方分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#CCCCCC" />

        <!-- 共X段视频 -->
        <TextView
            android:id="@+id/tv_part_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:text="共0段视频"
            android:textSize="14sp"
            android:textColor="#FCA3C5"
            android:paddingLeft="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <!-- 粉色分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3px"
            android:background="#FCA3C5" />

        <!-- 分P列表（使用自定义可滚动ListView） -->
        <tv.biliclassic.ObservableListView
            android:id="@+id/lv_parts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp" />

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>

</ScrollView>